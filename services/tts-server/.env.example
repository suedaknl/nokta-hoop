HOST=0.0.0.0
PORT=8790
TTS_PROVIDER=piper
TTS_CACHE_DIR=cache
TTS_MODEL_DIR=models
TTS_MAX_TEXT_LENGTH=1000

CHATTERBOX_DEVICE=auto
CHATTERBOX_LANGUAGE_ID=tr
CHATTERBOX_AUDIO_PROMPT_PATH=

